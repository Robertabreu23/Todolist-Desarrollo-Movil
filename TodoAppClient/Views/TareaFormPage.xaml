<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TodoAppClient.ViewModels"
             xmlns:models="clr-namespace:TodoAppClient.Models"
             x:Class="TodoAppClient.Views.TareaFormPage"
             x:DataType="vm:TareaFormViewModel"
             Title="{Binding Titulo}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}, FallbackValue=false}" />

            <Label Text="Nombre *" />
            <Entry Text="{Binding Nombre}" Placeholder="Nombre de la tarea" />

            <Label Text="Descripción" />
            <Editor Text="{Binding Descripcion}"
                    AutoSize="TextChanges"
                    HeightRequest="80"
                    Placeholder="Opcional" />

            <Label Text="Prioridad" />
            <Picker ItemsSource="{Binding Prioridades}"
                    SelectedItem="{Binding Prioridad}" />

            <HorizontalStackLayout Spacing="8">
                <CheckBox IsChecked="{Binding TieneVencimiento}" VerticalOptions="Center" />
                <Label Text="Tiene fecha de vencimiento" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Label Text="Fecha de vencimiento" IsVisible="{Binding TieneVencimiento}" />
            <DatePicker Date="{Binding FechaVencimientoDate}"
                        IsVisible="{Binding TieneVencimiento}" />

            <Label Text="Hora de vencimiento" IsVisible="{Binding TieneVencimiento}" />
            <TimePicker Time="{Binding FechaVencimientoTime}"
                        IsVisible="{Binding TieneVencimiento}" />

            <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsEditMode}">
                <CheckBox IsChecked="{Binding Completada}" VerticalOptions="Center" />
                <Label Text="Completada" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,0">
                <Button Grid.Column="0"
                        Text="Cancelar"
                        Command="{Binding CancelarCommand}" />
                <Button Grid.Column="1"
                        Text="Guardar"
                        Command="{Binding GuardarCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
